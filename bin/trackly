async function cmdCompanyBrief(args) {
  const id = parseJobId(args._[0]);
  if (id === null) failNow('Company ID must be a positive integer. Usage: trackly company-brief <companyId> [--refresh]');
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  try {
    if (args.refresh) {
      const result = await apiRequest('POST', `/api/network/companies/${id}/brief/refresh`);
      if (isJSON()) return printJson(result);
      console.log(color('green', 'Company brief refresh triggered.'));
      outputCompanyBrief(result.brief || result);
    } else {
      const result = await apiRequest('GET', `/api/network/companies/${id}/brief`);
      if (isJSON()) return printJson(result);
      const brief = result.brief || result;
      if (!brief || (typeof brief === 'object' && Object.keys(brief).length === 0)) {
        console.log(color('dim', 'No brief available. Use --refresh to generate.'));
      } else {
        outputCompanyBrief(brief);
      }
    }
  } catch (e) {
    setApiErrorExit(e, 'Failed to fetch company brief');
  }
}

