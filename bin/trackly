#!/usr/bin/env node
'use strict';

const {
  DEFAULT_BASE_URL,
  apiRequest,
  clearConfig,
  createTracklyAccessError,
  getApiKey,
  getAuthMethod,
  getBaseUrl,
  getConfigPaths,
  hasAuth,
  maintenanceOutput,
  loadConfig,
  saveConfig,
} = require('../lib/client');
const { color, isJSON, outputJobs, outputCompanies, outputStats, outputContacts, outputReferralCampaign, outputNetworkBrief, outputCompanyBrief, outputCompanyWorkspace, outputError } = require('../lib/formatters');
const http = require('http');
const crypto = require('crypto');
const { spawnSync } = require('child_process');
const { version: VERSION } = require('../package.json');
const { doctorAgent, resumeValidationStatus, setupAgent } = require('../lib/agent');

const BOOLEAN_FLAGS = new Set(['help', 'h', 'json', 'version', 'v', 'clear-api-key', 'clear-base-url', 'refresh', 'remote']);
const VALUE_FLAGS = new Set([
  'api-key',
  'base-url',
  'client',
  'company',
  'function',
  'job-type',
  'keywords',
  'limit',
  'name',
  'notes',
  'offset',
  'region',
  'search',
  'sort',
  'status',
  'url',
  'window-days',
  'target-reviewed-runs',
]);

// Flags accepted on ANY command. `api-key`/`base-url` are global overrides consumed
// in main() before dispatch; help/version are handled by early-returns.
const UNIVERSAL_FLAGS = new Set(['json', 'help', 'h', 'version', 'v', 'api-key', 'base-url']);

// Per-command allow-lists — each set is the flags that command's handler actually
// reads. Keyed at the command level (the union across a command's subcommands) so a
// valid filtered detail call like `jobs 123 --region us` is never falsely rejected,
// while typos (`--regoin`) and wrong-command flags (`jobs --url`, `jobs --search`)
// still are. `jobs` includes the deprecated `location`/`modality` so they reach the
// richer DEPRECATED_JOB_FLAGS migration message in cmdJobs rather than a generic error.
// Commands NOT listed here (e.g. `mcp`, or an unknown command) skip flag validation —
// the dispatcher reports unknown commands itself.
const COMMAND_FLAGS = {
  login: [],
  logout: [],
  whoami: [],
  jobs: ['function', 'company', 'region', 'job-type', 'work-arrangement', 'remote', 'status', 'sort', 'limit', 'offset', 'keywords', 'location', 'modality'],
  job: [],
  companies: ['limit', 'offset'],
  search: [],
  stats: [],
  status: [],
  preferences: [],
  apply: [],
  save: [],
  dismiss: [],
  ask: [],
  contacts: ['search', 'limit', 'offset'],
  referral: [],
  brief: [],
  'company-brief': ['refresh'],
  'company-workspace': [],
  'request-company': ['url', 'notes'],
  'api-key': ['name'],
  config: ['api-key', 'base-url', 'clear-api-key', 'clear-base-url'],
  agent: ['client', 'window-days', 'target-reviewed-runs'],
};
const AUTH_HELP_TEXT = `Not authenticated.
  Existing member: trackly login                 (Google OAuth)
  Existing API key: trackly config --api-key trk_xxx
  New member: Trackly is in a limited rollout. Request access at
              https://usetrackly.app/early-access`;
const STATUS_LABELS = {
  applied: 'applied',
  saved: 'saved',
  dismissed: 'dismissed',
};
const WORK_ARRANGEMENT_VALUES = ['remote', 'hybrid', 'in_person', 'unspecified'];
const JOB_FUNCTIONS = [
  'product', 'engineering', 'design', 'data', 'marketing', 'sales', 'partnerships',
  'finance', 'strategy', 'operations', 'people', 'legal', 'support', 'other',
];

function loginAccessError(code) {
  return createTracklyAccessError({ code });
}

function writeLoginProgress(message) {
  if (isJSON()) {
    console.error(message);
  } else {
    console.log(message);
  }
}

function parseArgs(args) {
  const result = { _: [], command: null };

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];

    if (arg === '--') {
      result._.push(...args.slice(i + 1));
      break;
    }

    if (arg === '-h') {
      result.help = true;
      continue;
    }

    if (arg === '-v') {
      result.version = true;
      continue;
    }

    if (arg.startsWith('--')) {
      const equalIndex = arg.indexOf('=');
      if (equalIndex !== -1) {
        const key = arg.slice(2, equalIndex);
        const value = arg.slice(equalIndex + 1);
        result[key] = value === '' ? true : value;
        continue;
      }

      const key = arg.slice(2);
      const nextArg = args[i + 1];
      if (VALUE_FLAGS.has(key)) {
        if (nextArg && !nextArg.startsWith('-')) {
          result[key] = nextArg;
          i++;
        } else {
          result[key] = null;
        }
        continue;
      }

      const expectsValue = !BOOLEAN_FLAGS.has(key) && nextArg && !nextArg.startsWith('-');

      if (expectsValue) {
        result[key] = nextArg;
        i++;
      } else {
        result[key] = true;
      }
      continue;
    }

    if (!result.command) result.command = arg;
    else result._.push(arg);
  }

  return result;
}

// Tiny Levenshtein (no dep) for "did you mean" flag suggestions.
function levenshtein(a, b) {
  const m = a.length;
  const n = b.length;
  const dp = Array.from({ length: m + 1 }, () => new Array(n + 1).fill(0));
  for (let i = 0; i <= m; i++) dp[i][0] = i;
  for (let j = 0; j <= n; j++) dp[0][j] = j;
  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      dp[i][j] = Math.min(
        dp[i - 1][j] + 1,
        dp[i][j - 1] + 1,
        dp[i - 1][j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1)
      );
    }
  }
  return dp[m][n];
}

function nearestFlag(key, allowed) {
  let best = null;
  let bestDistance = Infinity;
  for (const flag of allowed) {
    const d = levenshtein(key, flag);
    if (d < bestDistance) {
      bestDistance = d;
      best = flag;
    }
  }
  return bestDistance <= 2 ? best : null;
}

// Reject flags that the resolved command doesn't accept. Catches typos
// (`--regoin`) and wrong-command flags (`jobs --url`) that parseArgs would
// otherwise capture and the handler would silently ignore — returning, e.g., an
// unfiltered job feed that looks filtered. Unknown commands (and `mcp`) skip this;
// the dispatcher reports unknown commands itself.
function validateFlags(args) {
  const cmd = args.command;
  if (!cmd || !Object.prototype.hasOwnProperty.call(COMMAND_FLAGS, cmd)) return;
  const allowed = new Set([...UNIVERSAL_FLAGS, ...COMMAND_FLAGS[cmd]]);
  for (const key of Object.keys(args)) {
    if (key === '_' || key === 'command') continue;
    if (allowed.has(key)) continue;
    // Strip non-printable chars so a crafted `--$'\x1b[…'` flag can't inject
    // terminal escape sequences into the error message.
    const safe = String(key).replace(/[^\x20-\x7e]/g, '');
    const suggestion = nearestFlag(key, allowed);
    const hint = suggestion ? ` Did you mean --${suggestion}?` : '';
    failNow(`Unknown option --${safe} for 'trackly ${cmd}'.${hint} Run \`trackly --help\` for valid options.`);
  }
}

function failNow(message, exitCode = 1) {
  outputError(message);
  process.exit(exitCode);
}

function setErrorExit(message, exitCode = 1) {
  outputError(message);
  process.exitCode = exitCode;
}

function formatMaintenanceForHuman(maintenance) {
  const context = [
    maintenance.message,
    `Code: ${maintenance.code}; HTTP status: ${maintenance.status}; service status: ${maintenance.serviceStatus}.`,
  ];
  if (maintenance.requestId) context.push(`Request ID: ${maintenance.requestId}.`);
  context.push(maintenance.guidance);
  return context.join('\n');
}

function setApiErrorExit(error, fallbackMessage, exitCode = 1) {
  const maintenance = maintenanceOutput(error);
  const accessError = createTracklyAccessError(error, error?.status);
  if (isJSON() && accessError) {
    printJson({
      status: accessError.status,
      code: accessError.code,
      message: accessError.message,
      retryable: accessError.retryable,
    });
  } else if (maintenance && isJSON()) {
    printJson(maintenance);
  } else if (maintenance) {
    outputError(formatMaintenanceForHuman(maintenance));
  } else {
    outputError(error?.error || error?.message || fallbackMessage);
  }
  process.exitCode = exitCode;
}

function printJson(data) {
  console.log(JSON.stringify(data, null, 2));
}

function parseJobId(value) {
  const normalized = String(value || '').trim();
  if (!/^\d+$/.test(normalized)) return null;

  const id = Number(normalized);
  if (!Number.isSafeInteger(id) || id <= 0) return null;

  return id;
}

function parseExperienceLimits(values) {
  if (!Array.isArray(values) || values.length === 0) {
    throw new Error('Provide at least one role limit or `clear` (for example, `product=2 strategy=5`).');
  }
  if (values.includes('clear')) {
    if (values.length !== 1) throw new Error('`clear` cannot be combined with role limits.');
    return {};
  }

  const limits = {};
  for (const value of values) {
    const match = /^([^=]+)=([^=]+)$/.exec(String(value));
    if (!match) throw new Error(`Invalid limit "${value}". Use role=years (for example, product=2).`);
    const jobFunction = match[1].trim().toLowerCase();
    const rawYears = match[2].trim();
    if (!JOB_FUNCTIONS.includes(jobFunction)) {
      throw new Error(`Unknown job function "${jobFunction}". Use: ${JOB_FUNCTIONS.join(', ')}.`);
    }
    if (Object.prototype.hasOwnProperty.call(limits, jobFunction)) {
      throw new Error(`Duplicate limit for ${jobFunction}. Provide each job function once.`);
    }
    if (!/^\d+$/.test(rawYears)) {
      throw new Error(`Limit for ${jobFunction} must be an integer from 0 to 60.`);
    }
    const years = Number(rawYears);
    if (!Number.isInteger(years) || years < 0 || years > 60) {
      throw new Error(`Limit for ${jobFunction} must be an integer from 0 to 60.`);
    }
    limits[jobFunction] = years;
  }
  return limits;
}

// Flags deprecated in the API-docs-plan fixup. Still accepted by parseArgs so old
// scripts don't ERR_NOT_FOUND, but cmdJobs hard-rejects them with a migration hint
// — silent no-op would be worse than noise (per PR #13 Codex P1 finding).
const DEPRECATED_JOB_FLAGS = Object.freeze({
  location: '--location was removed. Use --region <tag> (us, non_us, all, or a region tag like europe, canada, remote). See `trackly --help` for accepted values.',
  modality: '--modality was removed. Use --job-type <full_time|internship|all> for employment type, and/or --remote / --region remote for work-location.',
});

function hasJobListFilters(args) {
  // Include deprecated flags so `trackly jobs 42 --location us` routes to cmdJobs
  // (which then raises the migration error) instead of cmdJob(42) silently ignoring
  // the filter. See PR #13 Cursor Bugbot finding.
  const deprecated = Object.keys(DEPRECATED_JOB_FLAGS);
  const active = ['function', 'company', 'keywords', 'limit', 'region', 'job-type', 'work-arrangement', 'remote', 'offset', 'sort', 'status'];
  return [...active, ...deprecated].some((key) => args[key] !== undefined);
}

function openExternalUrl(url) {
  let command = null;
  let args = [];

  if (process.platform === 'darwin') {
    command = 'open';
    args = [url];
  } else if (process.platform === 'linux') {
    command = 'xdg-open';
    args = [url];
  } else if (process.platform === 'win32') {
    command = 'cmd';
    args = ['/c', 'start', '', url];
  }

  if (!command) return false;

  const result = spawnSync(command, args, { stdio: 'ignore' });
  return !result.error && result.status === 0;
}

function normalizeBaseUrlValue(rawValue) {
  const value = String(rawValue || '').trim();
  if (!value) {
    throw new Error('Base URL cannot be empty');
  }

  const url = new URL(value);
  if (!['http:', 'https:'].includes(url.protocol)) {
    throw new Error('Base URL must start with http:// or https://');
  }

  return value.replace(/\/+$/, '');
}

function getPublicConfig() {
  const config = loadConfig();
  const { file } = getConfigPaths();
  const authMethod = getAuthMethod();

  return {
    configFile: file,
    baseUrl: getBaseUrl(),
    authMethod: authMethod === 'apiKey' ? 'api_key' : authMethod || 'none',
    hasApiKey: Boolean(getApiKey()),
    hasToken: Boolean(config.token),
    hasRefreshToken: Boolean(config.refreshToken),
  };
}

// -- Commands --

async function cmdLogin({ openUrl = openExternalUrl } = {}) {
  const baseUrl = getBaseUrl();
  const state = crypto.randomBytes(16).toString('hex');

  writeLoginProgress(color('cyan', 'Opening browser for Google login...'));

  let activeServer = null;

  function tryLogin() {
    return new Promise((resolve, reject) => {
      let settled = false;
      let timeoutId = null;

      const server = http.createServer((req, res) => {
        // Base is only used to parse req.url's path + query; the port is irrelevant.
        const url = new URL(req.url, 'http://127.0.0.1');
        if (url.pathname === '/callback') {
          const returnedState = url.searchParams.get('state');
          if (returnedState !== state) {
            res.writeHead(403, { 'Content-Type': 'text/html' });
            res.end('<html><body><h2>Login failed. Invalid state parameter (possible CSRF).</h2></body></html>');
            settle(new Error('CSRF state mismatch'));
            return;
          }

          const token = url.searchParams.get('token');
          const refreshToken = url.searchParams.get('refreshToken');
          const accessError = loginAccessError(url.searchParams.get('error'));
          if (accessError) {
            res.writeHead(403, {
              'Content-Type': 'text/html',
              'Referrer-Policy': 'no-referrer',
              'Cache-Control': 'no-store',
            });
            res.end('<html><body><h2>Trackly access is limited right now.</h2><p>Return to your terminal for next steps.</p></body></html>');
            const loginError = new Error(accessError.message);
            loginError.code = accessError.code;
            loginError.status = accessError.status;
            loginError.retryable = accessError.retryable;
            settle(loginError);
            return;
          }
          if (token) {
            const config = loadConfig();
            const hadApiKey = Boolean(config.apiKey);
            delete config.apiKey;
            saveConfig({ ...config, token, refreshToken, baseUrl });
            res.writeHead(200, { 'Content-Type': 'text/html', 'Referrer-Policy': 'no-referrer' });
            res.end(`<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Trackly CLI</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#0a0a0a;color:#fafafa;display:flex;align-items:center;justify-content:center;min-height:100vh}
.card{text-align:center;padding:48px 40px;max-width:420px}
.icon{margin-bottom:24px}
.check{width:48px;height:48px;border-radius:50%;background:#22c55e;display:inline-flex;align-items:center;justify-content:center;margin-bottom:20px}
.check svg{width:24px;height:24px}
h1{font-size:22px;font-weight:600;margin-bottom:8px;letter-spacing:-0.02em}
p{color:#a1a1aa;font-size:15px;line-height:1.5}
.hint{margin-top:24px;padding:12px 16px;background:#18181b;border:1px solid #27272a;border-radius:8px;font-family:'SF Mono','Fira Code',monospace;font-size:13px;color:#71717a}
</style>
</head>
<body>
<div class="card">
<div class="icon"><svg width="56" height="56" viewBox="0 0 56 56" fill="none"><rect width="56" height="56" rx="14" fill="#18181b"/><path d="M16 20h24v4H16zm0 8h18v4H16zm0 8h22v4H16z" fill="#22c55e" opacity="0.9"/></svg></div>
<div class="check"><svg fill="none" stroke="white" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
<h1>You're logged in</h1>
<p>You can close this tab and return to your terminal.</p>
<div class="hint">trackly search "PM jobs in SF"</div>
</div>
</body>
</html>`);
            writeLoginProgress(color('green', 'Login successful!'));
            if (hadApiKey) {
              writeLoginProgress('Switched to OAuth. Stored API key cleared.');
            }
            settle();
          } else {
            res.writeHead(400, { 'Content-Type': 'text/html' });
            res.end('<html><body><h2>Login failed. No token received.</h2></body></html>');
            settle(new Error('No token received'));
          }
        } else {
          res.writeHead(404);
          res.end();
        }
      });

      const settle = (error = null) => {
        if (settled) return;
        settled = true;
        if (timeoutId) clearTimeout(timeoutId);

        const finish = () => {
          if (error) {
            if (!createTracklyAccessError(error, 403)) {
              writeLoginProgress('\nLogin failed. Existing members can try API key auth:');
              writeLoginProgress('  1. Sign in at https://usetrackly.app');
              writeLoginProgress('  2. Go to Settings → API Keys → Create');
              writeLoginProgress('  3. Run: trackly config --api-key <your-key>');
            }
            reject(error);
          } else {
            resolve();
          }
        };

        if (server.listening) {
          server.close(finish);
        } else {
          finish();
        }
      };

      activeServer = server;

      server.on('error', (err) => {
        settle(err);
      });

      // Port 0 → OS-assigned ephemeral port, always free (no fixed-range collision,
      // so no retry loop needed). Verify it lands in the backend's accepted range.
      server.listen(0, '127.0.0.1', () => {
        const port = server.address().port;
        if (!Number.isInteger(port) || port < 1024 || port > 65535) {
          settle(new Error(`OS assigned an out-of-range callback port (${port}); expected 1024-65535.`));
          return;
        }
        writeLoginProgress(color('dim', `Callback server on port ${port}`));
        const loginUrl = `${baseUrl}/auth/google/cli?port=${port}&state=${state}`;
        if (!openUrl(loginUrl)) {
          writeLoginProgress(`Open this URL in your browser:\n${loginUrl}`);
        }
      });

      timeoutId = setTimeout(() => {
        settle(new Error('Login timed out'));
      }, 300000);
    });
  }

  // One SIGINT handler for the whole login (not per-attempt): close the active
  // callback server and exit cleanly on Ctrl-C, then always remove the handler so
  // it can't leak. (No EADDRINUSE retry path now, so no handler-leak edge case.)
  const onSigint = () => {
    if (activeServer) {
      try { activeServer.close(); } catch (_) {}
    }
    process.exit(130);
  };
  process.on('SIGINT', onSigint);
  try {
    await tryLogin();
    if (isJSON()) printJson({ success: true, authMethod: 'oauth' });
  } finally {
    process.removeListener('SIGINT', onSigint);
  }
}

async function cmdLogout() {
  clearConfig();
  console.log(color('green', 'Logged out. Credentials cleared.'));
}

async function cmdWhoami() {
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  try {
    const result = await apiRequest('GET', '/api/auth/user');
    const user = result.user || result;

    if (result.success || result.user || result.email) {
      if (isJSON()) return printJson(user);
      console.log(`${color('bold', user.name || 'Unknown')}`);
      console.log(`  Email: ${color('cyan', user.email)}`);
      if (user.id !== undefined) {
        console.log(`  ID: ${color('dim', user.id)}`);
      }
    } else {
      setErrorExit(AUTH_HELP_TEXT);
    }
  } catch (e) {
    setApiErrorExit(e, 'Failed to get user info');
  }
}

async function cmdJobs(args) {
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  // Reject deprecated flags with migration hints instead of silently ignoring them
  // (scripts from older releases would otherwise appear to succeed while returning
  // an unfiltered feed — misleading and hard to debug).
  for (const [flag, hint] of Object.entries(DEPRECATED_JOB_FLAGS)) {
    if (args[flag] !== undefined) failNow(hint);
  }

  // --remote is a shorthand that conflicts with --region (they both control location).
  // Help text documents them as alternatives; enforce it explicitly here.
  if (args.remote && args.region) {
    failNow('--remote cannot be combined with --region. Use one or the other (e.g. --region remote).');
  }

  let workArrangements;
  if (args['work-arrangement'] !== undefined) {
    if (typeof args['work-arrangement'] !== 'string' || !args['work-arrangement'].trim()) {
      failNow('--work-arrangement requires a comma-separated value: remote, hybrid, in_person, unspecified.');
    }
    workArrangements = [...new Set(args['work-arrangement'].split(',').map((value) => value.trim()))];
    const invalid = workArrangements.filter((value) => !WORK_ARRANGEMENT_VALUES.includes(value));
    if (invalid.length > 0) {
      failNow(`Invalid --work-arrangement value "${invalid.join(',')}". Use: ${WORK_ARRANGEMENT_VALUES.join(', ')}.`);
    }
  }

  const params = new URLSearchParams();
  if (args.function) params.set('jobFunction', args.function);
  if (args.company) params.set('companyId', args.company);
  if (args.region) params.set('locationFilter', args.region);
  if (args['job-type']) params.set('jobModality', args['job-type']);
  if (workArrangements) params.set('workArrangements', workArrangements.join(','));
  if (args.remote) params.set('usStates', 'REMOTE');
  if (args.status) params.set('status', args.status);
  if (args.sort) params.set('sort', args.sort);
  if (args.limit) params.set('limit', args.limit);
  if (args.offset) params.set('offset', args.offset);
  if (args.keywords) params.set('search', args.keywords);

  const qs = params.toString();
  try {
    const result = await apiRequest('GET', `/api/jobscout/jobs${qs ? '?' + qs : ''}`);
    outputJobs(result.jobs || result.data || []);
    if (!isJSON() && result.total) {
      console.log(color('dim', `Showing ${(result.jobs || result.data || []).length} of ${result.total} jobs`));
    }
  } catch (e) {
    setApiErrorExit(e, 'Failed to fetch jobs');
  }
}

async function cmdJob(args) {
  const id = parseJobId(args._[0]);
  if (id === null) failNow('Job ID must be a positive integer. Usage: trackly job <id>');
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  try {
    const result = await apiRequest('GET', `/api/jobscout/jobs/${id}`);
    if (isJSON()) return printJson(result);

    const job = result.job || result;
    console.log(color('bold', job.title));
    console.log(`Company: ${color('blue', job.companyName || (job.company && job.company.name) || '')}`);
    if (job.location) console.log(`Location: ${job.location}`);
    if (job.jobUrl) console.log(`URL: ${color('dim', job.jobUrl)}`);
    if (job.postedAt) console.log(`Posted: ${job.postedAt}`);
    if (typeof job.description === 'string' && job.description.length > 0) {
      console.log();
      console.log(color('bold', 'Description:'));
      console.log(job.description.slice(0, 1000));
      if (job.description.length > 1000) console.log(color('dim', '... (truncated)'));
    }
  } catch (e) {
    setApiErrorExit(e, 'Failed to fetch job');
  }
}

async function cmdCompanies(args) {
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  const params = new URLSearchParams();
  if (args.limit) params.set('limit', args.limit);
  if (args.offset) params.set('offset', args.offset);

  try {
    const qs = params.toString();
    const result = await apiRequest('GET', `/api/jobscout/companies${qs ? '?' + qs : ''}`);
    outputCompanies(result.companies || result.data || []);
  } catch (e) {
    setApiErrorExit(e, 'Failed to fetch companies');
  }
}

async function cmdSearch(args) {
  const query = args._.join(' ').trim();
  if (!query) failNow('Search query required. Usage: trackly search "fintech"');
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  try {
    const result = await apiRequest('GET', `/api/jobscout/companies/search?q=${encodeURIComponent(query)}`);
    outputCompanies(result.companies || result.results || []);
  } catch (e) {
    setApiErrorExit(e, 'Failed to search');
  }
}

async function cmdStats() {
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  try {
    const result = await apiRequest('GET', '/api/jobscout/me');
    outputStats(result);
  } catch (e) {
    setApiErrorExit(e, 'Failed to fetch stats');
  }
}

function renderPreferences(result) {
  const user = result?.user || {};
  const preferences = user.preferences || result?.preferences || {};
  const limits = preferences.experienceLimitsByJobFunction || {};

  console.log(color('bold', 'Discovery preferences'));
  const selected = Array.isArray(preferences.wantedJobFunctions)
    ? preferences.wantedJobFunctions
    : [];
  console.log(`  Target roles: ${selected.length > 0 ? selected.join(', ') : 'All roles'}`);
  console.log(`  Experience limits: ${Object.keys(limits).length > 0 ? 'Configured' : 'Not configured'}`);
  for (const [jobFunction, years] of Object.entries(limits)) {
    console.log(`    ${jobFunction}: Up to ${years} year${years === 1 ? '' : 's'} required`);
  }
  console.log(color('dim', '  Jobs with no stated minimum remain visible.'));
  console.log(color('dim', '  This confirms what you saved; it does not show whether Trackly is currently applying the limits.'));
  if (Number.isSafeInteger(preferences.discoveryPreferenceRevision)) {
    console.log(color('dim', `  Revision: ${preferences.discoveryPreferenceRevision}`));
  }
}

function projectPreferenceResponse(result, experienceFilterV2Available = null) {
  const user = result?.user || {};
  return {
    success: result?.success === true,
    experienceFilterV2Available: experienceFilterV2Available === null
      ? user.experienceFilterV2Available === true
      : experienceFilterV2Available === true,
    preferences: user.preferences || result?.preferences || {},
  };
}

function handlePreferenceConflict(error) {
  const message = 'Preferences changed on another device. Review `trackly preferences`, then run the update again.';
  if (isJSON()) {
    printJson({
      status: error.status,
      code: error.error,
      message,
      preferences: error.preferences,
      discoveryPreferenceRevision: error.discoveryPreferenceRevision,
    });
  } else {
    outputError(message);
  }
  process.exitCode = 1;
}

async function cmdPreferences(args) {
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  const subcommand = args._[0];
  if (subcommand == null || subcommand === 'show') {
    if (args._.length > (subcommand === 'show' ? 1 : 0)) {
      failNow('Usage: trackly preferences [show]');
    }
    try {
      const result = await apiRequest('GET', '/api/jobscout/me');
      if (isJSON()) return printJson(projectPreferenceResponse(result));
      renderPreferences(result);
      return;
    } catch (error) {
      setApiErrorExit(error, 'Failed to fetch preferences');
      return;
    }
  }

  if (subcommand !== 'experience') {
    failNow('Unknown preferences subcommand. Use: trackly preferences [show] | trackly preferences experience <role=years...|clear>');
  }

  let experienceLimitsByJobFunction;
  try {
    experienceLimitsByJobFunction = parseExperienceLimits(args._.slice(1));
  } catch (error) {
    failNow(error.message);
  }

  try {
    // Read immediately before the write and send the authoritative revision.
    // The backend rejects a stale value with 409 instead of letting this
    // process overwrite a newer iOS, web, macOS, CLI, or MCP save.
    const current = await apiRequest('GET', '/api/jobscout/me');
    if (current?.user?.experienceFilterV2Available !== true) {
      failNow('Role-specific experience preferences are not available for this account yet. No changes were saved.');
    }
    const expectedPreferenceRevision = current?.user?.preferences?.discoveryPreferenceRevision;
    if (!Number.isSafeInteger(expectedPreferenceRevision) || expectedPreferenceRevision < 0) {
      failNow('Trackly did not return a valid preference revision. No changes were saved.');
    }

    const result = await apiRequest('PUT', '/api/jobscout/preferences', {
      experienceLimitsByJobFunction,
      experienceFilterVersion: 2,
      expectedPreferenceRevision,
    });
    if (isJSON()) return printJson(projectPreferenceResponse(result, true));
    console.log(color(
      'green',
      Object.keys(experienceLimitsByJobFunction).length > 0
        ? 'Role-specific experience limits updated.'
        : 'Role-specific experience filtering turned off.',
    ));
    renderPreferences(result);
  } catch (error) {
    if (error?.status === 409 && error?.error === 'preference_revision_conflict') {
      handlePreferenceConflict(error);
      return;
    }
    setApiErrorExit(error, 'Failed to update experience limits');
  }
}

const ACTION_TO_COMMAND = { applied: 'apply', saved: 'save', dismissed: 'dismiss' };

// CLI surface accepts applied|saved|dismissed (legacy human-friendly terms).
// Backend `/api/jobscout/tracker/jobs/:id/stage` expects stage values:
//   applied → applied, saved → backlog, dismissed → discarded
// The old `/api/jobscout-tracker/status` endpoint was removed; the new stage
// endpoint is what production actually serves (and what hosted MCP uses).
const ACTION_TO_STAGE = { applied: 'applied', saved: 'backlog', dismissed: 'discarded' };

async function cmdUpdateStatus(id, action) {
  const jobId = parseJobId(id);
  if (jobId === null) failNow(`Job ID must be a positive integer. Usage: trackly ${ACTION_TO_COMMAND[action] || action} <id>`);
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  // action is already validated by the command dispatcher (apply/save/dismiss subcommands
  // pass literal strings). No `|| action` fallback — if ACTION_TO_STAGE is ever widened
  // without updating the dispatcher (or vice versa), fail loud rather than silently POST
  // an unintended stage value (e.g., posting stage='snoozed' when backend only knows the
  // stage column's allowlist). Mirrors the defensive throw in mcp/server.js.
  const stage = ACTION_TO_STAGE[action];
  if (!stage) {
    failNow(`Internal error: unknown action "${action}" — expected applied|saved|dismissed.`);
  }
  try {
    const result = await apiRequest('POST', `/api/jobscout/tracker/jobs/${jobId}/stage`, { stage });
    if (isJSON()) return printJson(result);
    console.log(color('green', `Job ${jobId} marked as ${STATUS_LABELS[action]}.`));
  } catch (e) {
    setApiErrorExit(e, `Failed to ${action} job`);
  }
}

async function cmdAsk(args) {
  const query = args._.join(' ');
  if (!query) failNow('Query required. Usage: trackly ask "PM jobs at fintech"');
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  try {
    const result = await apiRequest('GET', `/api/jobscout/ask?q=${encodeURIComponent(query)}`);
    if (isJSON()) return printJson(result);

    console.log(color('bold', 'Parsed filters:'));
    for (const [k, v] of Object.entries(result.parsedFilters || {})) {
      console.log(`  ${k}: ${color('cyan', String(v))}`);
    }

    if (result.jobsUrl) {
      // Path allowlist: /ask can return any string for jobsUrl. normalizeEndpoint already
      // blocks cross-origin fetches (baseUrl mismatch), but a compromised backend could
      // still emit a same-origin path like `/api/admin/secret-dump`. Restrict to the two
      // legitimate handlers that /ask is designed to route to.
      const JOBS_URL_ALLOWLIST = /^\/api\/(v1|jobscout)\/jobs(\?|$)/;
      if (!JOBS_URL_ALLOWLIST.test(result.jobsUrl)) {
        console.log(color('dim', `Refusing to follow unexpected jobsUrl: ${result.jobsUrl}`));
      } else {
        console.log();
        console.log(color('dim', `Fetching: ${result.jobsUrl}`));
        const jobsResult = await apiRequest('GET', result.jobsUrl);
        console.log();
        outputJobs(jobsResult.jobs || jobsResult.data || []);
      }
    }
  } catch (e) {
    if (e.status === 429) setErrorExit('Daily limit reached (20 natural language queries per day)');
    else setApiErrorExit(e, 'Failed to process query');
  }
}

async function cmdApiKey(args) {
  const subcommand = args._[0] || 'create';
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  if (subcommand === 'create') {
    const name = args.name || 'default';
    try {
      const result = await apiRequest('POST', '/api/auth/api-key', { name });
      if (isJSON()) return printJson(result);
      console.log(color('green', 'API key created!'));
      console.log();
      console.log(`Key: ${color('bold', result.key)}`);
      console.log(color('yellow', 'Save this key — it cannot be shown again.'));
      console.log(color('dim', 'Tip: run `trackly config --api-key <key>` or set TRACKLY_API_KEY to use it.'));
    } catch (e) {
      setApiErrorExit(e, 'Failed to create API key');
    }
  } else if (subcommand === 'list') {
    try {
      const result = await apiRequest('GET', '/api/auth/api-keys');
      if (isJSON()) return printJson(result.keys || []);
      for (const key of (result.keys || [])) {
        console.log(`${color('bold', key.key_prefix + '...')} — ${key.name} (created ${key.created_at})`);
      }
    } catch (e) {
      setApiErrorExit(e, 'Failed to list keys');
    }
  } else {
    failNow('Unknown api-key subcommand. Use: trackly api-key create | list');
  }
}

async function cmdContacts(args) {
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  const params = new URLSearchParams();
  const searchQuery = args.search || args._.join(' ').trim();
  if (searchQuery) params.set('search', searchQuery);
  if (args.limit) params.set('limit', args.limit);
  if (args.offset) params.set('offset', args.offset);

  const qs = params.toString();
  try {
    const result = await apiRequest('GET', `/api/network/people${qs ? '?' + qs : ''}`);
    outputContacts(result.contacts || result.people || result.data || []);
    if (!isJSON() && result.total) {
      console.log(color('dim', `Showing ${(result.contacts || result.people || result.data || []).length} of ${result.total} contacts`));
    }
  } catch (e) {
    setApiErrorExit(e, 'Failed to fetch contacts');
  }
}

