async function cmdRequestCompany(args) {
  // Positional arg = company name. Allow multi-word names without forcing the user
  // to quote, e.g. `trackly request-company Built Robotics --url ...` joins the
  // free-floating positionals into "Built Robotics". Matches `trackly ask` UX.
  const name = (args._ || []).join(' ').trim();
  if (!name) {
    failNow('Company name required. Usage: trackly request-company <name> [--url <url>] [--notes <notes>]');
  }
  if (!hasAuth()) failNow(AUTH_HELP_TEXT);

  const url = typeof args.url === 'string' ? args.url : '';
  const notes = typeof args.notes === 'string' ? args.notes : '';

  try {
    const result = await apiRequest('POST', '/api/jobscout/companies/request', {
      company_name: name,
      company_url: url,
      notes: notes,
      source: 'cli',
    });
    if (isJSON()) return printJson(result);
    const requestId = result.requestId || result.id || '?';
    console.log(color('green', `Requested "${name}" (#${requestId}). Trackly team will review shortly.`));
  } catch (e) {
    // Backend returns 429 (rate limit, max 5 pending) and 409 (duplicate pending request)
    // with a specific `error` message. Surface that message verbatim so the user knows
    // exactly which gate fired without having to enable --json.
    if (e.status === 429) {
      setApiErrorExit(e, 'Maximum 5 pending requests allowed. Please wait for existing requests to be reviewed.');
    } else if (e.status === 409) {
      setApiErrorExit(e, 'You already have a pending request for this company.');
    } else {
      setApiErrorExit(e, 'Failed to request company');
    }
  }
}

async function cmdConfig(args) {
  if (args['api-key'] === null) failNow('API key value required. Usage: trackly config --api-key <key>');
  if (args['base-url'] === null) failNow('Base URL value required. Usage: trackly config --base-url <url>');

  // Reject contradictory set+clear in the same invocation rather than silently
  // letting last-write-win produce surprising results.
  if (args['api-key'] !== undefined && args['clear-api-key']) {
    failNow('Cannot use --api-key and --clear-api-key together.');
  }
  if (args['base-url'] !== undefined && args['clear-base-url']) {
    failNow('Cannot use --base-url and --clear-base-url together.');
  }

  const config = loadConfig();
  let updated = false;

  if (args['clear-api-key']) {
    delete config.apiKey;
    updated = true;
    console.log(color('green', 'Stored API key cleared.'));
  }

  if (args['clear-base-url']) {
    delete config.baseUrl;
    updated = true;
    console.log(color('green', `Base URL reset to default (${DEFAULT_BASE_URL}).`));
  }

  if (args['api-key'] !== undefined) {
    const keyValue = String(args['api-key']).trim();
    if (keyValue.startsWith('trk_') && keyValue.length < 14) {
      failNow('Invalid API key: trk_ keys must be at least 14 characters (trk_ + 10). Run "trackly api-key create" to generate a valid key.');
    } else if (!keyValue.startsWith('trk_') && keyValue.length < 20) {
      failNow('Invalid API key: key does not start with trk_ and is too short (must be 20+ characters). Run "trackly api-key create" to generate a valid key.');
    } else if (!keyValue.startsWith('trk_')) {
      console.log(color('yellow', 'Warning: API key does not start with trk_ prefix. Saving as legacy/JWT key.'));
    }
    const hadToken = Boolean(config.token);
    config.apiKey = keyValue;
    delete config.token;
    delete config.refreshToken;
    updated = true;
    console.log(color('green', 'API key saved.'));
    if (hadToken) {
      console.log('Switched to API key auth. OAuth token cleared.');
    }
  }

  if (args['base-url'] !== undefined) {
    try {
      config.baseUrl = normalizeBaseUrlValue(args['base-url']);
    } catch (e) {
      failNow('Invalid base URL: ' + e.message);
    }
    updated = true;
    console.log(color('green', `Base URL set to ${config.baseUrl}.`));
  }

  if (updated) {
    saveConfig(config);
    console.log();
  }

  const publicConfig = getPublicConfig();
  if (isJSON()) return printJson(publicConfig);

  console.log(color('bold', 'Trackly Config'));
  console.log(`Config file: ${color('dim', publicConfig.configFile)}`);
  console.log(`Base URL: ${color('cyan', publicConfig.baseUrl)}`);
  console.log(`Auth method: ${color('cyan', publicConfig.authMethod)}`);
  console.log(`Stored API key: ${color(publicConfig.hasApiKey ? 'green' : 'dim', publicConfig.hasApiKey ? 'yes' : 'no')}`);
  console.log(`Stored token: ${color(publicConfig.hasToken ? 'green' : 'dim', publicConfig.hasToken ? 'yes' : 'no')}`);
  console.log(
    `Refresh token: ${color(publicConfig.hasRefreshToken ? 'green' : 'dim', publicConfig.hasRefreshToken ? 'yes' : 'no')}`
  );
}

async function cmdVersion() {
  console.log(VERSION);
}

async function cmdMcp() {
  await require('../mcp/server').startMcpServer();
}

async function cmdAgent(args) {
  const subcommand = args._[0];
  if (subcommand === 'setup') {
    if (args.client === null) return failNow('Missing value for --client. Use codex, claude, or both.');
    const client = String(args.client || 'both').toLowerCase();
    try {
      const result = setupAgent(client);
      const registrationFailed = result.clients.some((item) => !['current', 'installed'].includes(item.mcp.status));
      if (registrationFailed) process.exitCode = 1;
      if (isJSON()) return printJson(result);
      console.log(color('green', `Trackly Apply ${result.skillVersion} installed.`));
      console.log(`Canonical skill: ${result.canonical}`);
      for (const item of result.clients) {
        console.log(`${item.client}: skill ${item.status} (${item.method}); MCP ${item.mcp.status}`);
        if (item.mcp.error) console.log(color('yellow', `  ${item.mcp.error}`));
      }
      return;
    } catch (error) {
      const message = error.message || String(error);
      if (isJSON()) {
        process.exitCode = 1;
        return printJson({ error: message });
      }
      setErrorExit(message);
      return;
    }
  }
  if (subcommand === 'doctor') {
    const report = await doctorAgent();
    if (!report.ok) process.exitCode = 1;
    if (isJSON()) return printJson(report);
    console.log(color('bold', 'Trackly Apply doctor'));
    console.log(`Overall: ${color(report.ok ? 'green' : 'yellow', report.ok ? 'ready' : 'needs attention')}`);
    console.log(`Authenticated: ${report.authenticated ? 'yes' : 'no'}`);
    console.log(`Protocol: ${report.protocol?.version || 'unavailable'}; compatible=${report.compatible ? 'yes' : 'no'}`);
    console.log(`Semantic browser + computer use: ${report.browserControl.semanticReady ? 'ready' : 'not verified'}`);
    for (const client of report.clients) {
      console.log(`${client.client}: executable=${client.executable ? 'yes' : 'no'}, skill=${client.installed ? 'yes' : 'no'}, MCP=${client.mcpRegistered ? 'yes' : 'no'}`);
    }
    if (report.profile) {
      console.log(`Profile: ${report.profile.completeness?.percent ?? 0}% complete; default resume=${report.profile.hasDefaultResume ? 'yes' : 'no'}`);
      if (report.profile.completeness?.missingKeys?.length) {
        console.log(`Missing: ${report.profile.completeness.missingKeys.join(', ')}`);
      }
    }
    console.log(`Resume validation: ${resumeValidationStatus(report)}`);
    if (report.resume?.maintenance) {
      console.log(color('yellow', `Resume: ${formatMaintenanceForHuman(report.resume.maintenance)}`));
    } else if (report.resume?.error) {
      console.log(color('yellow', `Resume: ${report.resume.error}`));
    }
    if (report.apiError) {
      const apiErrorMessage = typeof report.apiError === 'string'
        ? report.apiError
        : formatMaintenanceForHuman(report.apiError);
      console.log(color('yellow', `API: ${apiErrorMessage}`));
    }
    console.log(report.browserControl.note);
    return;
  }
  if (subcommand === 'evidence') {
    const parseBoundedInteger = (value, fallback, flag, maximum) => {
      if (value === undefined) return fallback;
      if (value === null || !/^\d+$/.test(String(value))) {
        failNow(`${flag} must be an integer from 1 to ${maximum}.`);
      }
      const parsed = Number(value);
      if (!Number.isInteger(parsed) || parsed < 1 || parsed > maximum) {
        failNow(`${flag} must be an integer from 1 to ${maximum}.`);
      }
      return parsed;
    };
    const windowDays = parseBoundedInteger(args['window-days'], 90, '--window-days', 365);
    const targetReviewedRuns = parseBoundedInteger(
      args['target-reviewed-runs'],
      20,
      '--target-reviewed-runs',
      1000,
    );
    try {
      const result = await apiRequest(
        'GET',
        `/api/jobscout/apply/evidence?windowDays=${windowDays}&targetReviewedRuns=${targetReviewedRuns}`,
      );
      if (isJSON()) return printJson(result);
      const report = result.report;
      console.log(color('bold', 'Trackly Apply evidence'));
      console.log(`Window: last ${report.windowDays} days`);
      console.log(`Reviewed: ${report.summary.reviewedRuns}/${report.targetReviewedRuns}; submitted=${report.summary.submittedRuns}; blocked=${report.summary.blockedRuns}`);
      if (report.summary.excludedLegacyRuns) {
        console.log(`Excluded pre-evidence runs: ${report.summary.excludedLegacyRuns}`);
      }
      console.log(`Critical contact integrity: ${report.evidence.criticalContact.coveragePercent}% (${report.evidence.criticalContact.verifiedRuns}/${report.summary.reviewedRuns}); corrected=${report.evidence.criticalContact.correctedRuns}; unresolved=${report.evidence.criticalContact.unresolvedFailureRuns}`);
      console.log(`Manual-submit boundary: ${report.evidence.manualSubmitBoundary.coveragePercent}% (${report.evidence.manualSubmitBoundary.verifiedRuns}/${report.summary.reviewedRuns}); violations=${report.evidence.manualSubmitBoundary.violationRuns}`);
      for (const provider of report.providers) {
        console.log(`${provider.provider}: reviewed=${provider.reviewedRuns}; submitted=${provider.submittedRuns}; blocked=${provider.blockedRuns}`);
      }
      console.log(`Release gate: ${color(report.releaseGate.ready ? 'green' : 'yellow', report.releaseGate.ready ? 'ready' : 'not ready')}`);
      if (report.releaseGate.blockers.length) console.log(`Blockers: ${report.releaseGate.blockers.join(', ')}`);
      return;
    } catch (error) {
      setApiErrorExit(error, 'Failed to fetch Trackly Apply evidence');
      return;
    }
  }
  failNow('Unknown agent subcommand. Use: trackly agent setup --client codex|claude|both | trackly agent doctor | trackly agent evidence');
}

function showHelp() {
  console.log(`
${color('bold', 'trackly')} v${VERSION} — Trackly job tracker CLI + MCP server

${color('bold', 'Usage:')}
  trackly <command> [options]

${color('bold', 'Commands:')}
  ${color('cyan', 'login')}                Authenticate via Google OAuth
  ${color('cyan', 'logout')}               Clear credentials
  ${color('cyan', 'whoami')}               Show current user
  ${color('cyan', 'jobs')}                 List jobs (--function, --company <id>, --region <tag>, --job-type <type>, --work-arrangement <values>, --remote, --status, --sort, --limit, --offset, --keywords)
  ${color('cyan', 'job <id>')}             Get full job detail
  ${color('cyan', 'jobs <id>')}            Alias for job <id>
  ${color('cyan', 'companies')}            List companies
  ${color('cyan', 'companies search <q>')} Alias for semantic company search
  ${color('cyan', 'search <query>')}       Semantic company search
  ${color('cyan', 'stats')}                Show metrics dashboard
  ${color('cyan', 'status')}               Alias for stats
  ${color('cyan', 'preferences')}          Show discovery preferences
  ${color('cyan', 'preferences experience')} Replace role limits (role=years; clear turns off)
  ${color('cyan', 'apply <id>')}           Mark job as applied
  ${color('cyan', 'save <id>')}            Save a job
  ${color('cyan', 'dismiss <id>')}         Dismiss a job
  ${color('cyan', 'ask "query"')}          Natural language job search (20/day)
  ${color('cyan', 'contacts')}             List your contacts (--search, --limit, --offset)
  ${color('cyan', 'contacts search <q>')} Search contacts by name, company, or title
  ${color('cyan', 'referral start <id>')} Start a referral campaign for a job
  ${color('cyan', 'referral status <id>')} Check referral campaign progress
  ${color('cyan', 'brief <id>')}           Get network brief for a job
  ${color('cyan', 'company-brief <id>')}   Get company brief (--refresh to generate)
  ${color('cyan', 'company-workspace <id>')} Show company workspace (jobs, contacts, campaigns)
  ${color('cyan', 'request-company <name>')} Request a company be added to Trackly (--url, --notes)
  ${color('cyan', 'api-key create')}       Generate an API key
  ${color('cyan', 'api-key list')}         List your API keys
  ${color('cyan', 'config')}               Show or update CLI config (--api-key, --base-url)
  ${color('cyan', 'version')}              Show CLI version
  ${color('cyan', 'mcp')}                  Start MCP server
  ${color('cyan', 'agent setup')}          Install Trackly Apply for Codex/Claude (--client codex|claude|both)
  ${color('cyan', 'agent doctor')}         Verify auth, MCP, skill, profile, resume, and compatibility
  ${color('cyan', 'agent evidence')}       Show value-free beta evidence (--window-days, --target-reviewed-runs)

${color('bold', 'Flags:')}
  --api-key <key>       Use an API key for this command
  --base-url <url>      Override the Trackly API base URL for this command
  --json                Force JSON output
  --version             Show version
  --help                Show this help

${color('bold', 'Filter values:')}
  --function       product, engineering, design, data, marketing, sales, partnerships,
                   finance, strategy, operations, people, legal, support, other (comma-separated)
  experience limits use the same role values, for example:
                   trackly preferences experience product=2 strategy=5
                   When enforcement is active, includes jobs whose stated minimum is up to the limit.
                   Jobs with no stated minimum remain visible.
  --region         us, non_us, all, or a region tag (europe, canada, remote, ...)
                   Use a comma-separated list of region tags for multiple regions;
                   us/non_us/all cannot be combined.
  --job-type       full_time, internship, all  (employment type, not work-location)
  --work-arrangement
                   remote, hybrid, in_person, unspecified (comma-separated)
  --remote         Flag (no value). Filters for remote jobs (equivalent to usStates=REMOTE).
  --status         new, applied_confirmed, check_later, not_interested, all
                   (filters by YOUR application pipeline state)
  --sort           newest (default), match (highest match score first, requires resume)

${color('bold', 'MCP Setup:')}
  Claude Code: claude mcp add --scope user trackly -- trackly mcp
  Cursor: add {"command":"trackly","args":["mcp"]} to .cursor/mcp.json
`);
}

// -- Main --

async function main() {
  const args = parseArgs(process.argv.slice(2));

  if (args.command !== 'config' && args['api-key'] === null) {
    failNow('API key value required. Usage: trackly --api-key <key> <command>');
  }

  if (args.command !== 'config' && args['base-url'] === null) {
    failNow('Base URL value required. Usage: trackly --base-url <url> <command>');
  }

  if (args.command !== 'config' && args['api-key']) {
    process.env.TRACKLY_API_KEY = String(args['api-key']);
    // Warn once per invocation: --api-key on the command line is visible in `ps auxww` to
    // any local user AND lands in shell history (~/.zsh_history, ~/.bash_history). This
    // warning is a nudge, not a block — scripted pipelines can suppress via TRACKLY_NO_WARN=1.
    // Printed to stderr (not stdout) so `--json` consumers parsing stdout are unaffected.
    if (process.env.TRACKLY_NO_WARN !== '1') {
      process.stderr.write(
        '\x1b[33mWarning:\x1b[0m --api-key on the command line is visible in `ps` and shell history.\n' +
        '  Prefer: TRACKLY_API_KEY=trk_... trackly ... (env var)\n' +
        '       or: trackly config --api-key trk_... (persisted to ~/.trackly/config.json, mode 0600)\n' +
        '  Silence this warning: TRACKLY_NO_WARN=1\n'
      );
    }
    // Scrub the flag value from argv so subsequent inspection (diagnostics, crash reporters,
    // child processes that inherit argv) cannot recover the secret. The `ps` vector is
    // already lost the moment the process started — this only protects against in-process
    // leaks (e.g. an MCP tool accidentally logging process.argv).
    for (let i = 0; i < process.argv.length; i++) {
      if (process.argv[i] === '--api-key' && i + 1 < process.argv.length) {
        process.argv[i + 1] = '***';
      } else if (process.argv[i].startsWith('--api-key=')) {
        process.argv[i] = '--api-key=***';
      }
    }
  }

  if (args.command !== 'config' && args['base-url']) {
    try {
      process.env.TRACKLY_BASE_URL = normalizeBaseUrlValue(args['base-url']);
    } catch (e) {
      failNow('Invalid base URL: ' + e.message);
    }
  }

  if (args.version || args.v || args.command === 'version') {
    await cmdVersion();
    return;
  }

  if (!args.command || args.help || args.h) {
    showHelp();
    process.exit(0);
  }

  // Reject unknown / wrong-command flags AFTER the help+version early-returns
  // (so `trackly --help --weird` still shows help instead of erroring).
  validateFlags(args);

  switch (args.command) {
    case 'login':
      await cmdLogin();
      break;
    case 'logout':
      await cmdLogout();
      break;
    case 'whoami':
      await cmdWhoami();
      break;
    case 'jobs':
      if (parseJobId(args._[0]) !== null && !hasJobListFilters(args)) {
        await cmdJob({ ...args, _: [args._[0]] });
      } else {
        await cmdJobs(args);
      }
      break;
    case 'job':
      await cmdJob(args);
      break;
    case 'companies':
      if (args._[0] === 'search') {
        await cmdSearch({ ...args, _: args._.slice(1) });
      } else {
        await cmdCompanies(args);
      }
      break;
    case 'search':
      await cmdSearch(args);
      break;
    case 'stats':
    case 'status':
      await cmdStats();
      break;
    case 'preferences':
      await cmdPreferences(args);
      break;
    case 'apply':
      await cmdUpdateStatus(args._[0], 'applied');
      break;
    case 'save':
      await cmdUpdateStatus(args._[0], 'saved');
      break;
    case 'dismiss':
      await cmdUpdateStatus(args._[0], 'dismissed');
      break;
    case 'ask':
      await cmdAsk(args);
      break;
    case 'contacts':
      if (args._[0] === 'search') {
        await cmdContacts({ ...args, _: [], search: args._.slice(1).join(' ') });
      } else {
        await cmdContacts(args);
      }
      break;
    case 'referral':
      if (args._[0] === 'start') {
        await cmdReferralStart({ ...args, _: args._.slice(1) });
      } else if (args._[0] === 'status') {
        await cmdReferralStatus({ ...args, _: args._.slice(1) });
      } else {
        failNow('Unknown referral subcommand. Use: trackly referral start <id> | trackly referral status <id>');
      }
      break;
    case 'brief':
      await cmdBrief(args);
      break;
    case 'company-brief':
      await cmdCompanyBrief(args);
      break;
    case 'company-workspace':
      await cmdCompanyWorkspace(args);
      break;
    case 'request-company':
      await cmdRequestCompany(args);
      break;
    case 'api-key':
      await cmdApiKey(args);
      break;
    case 'config':
      await cmdConfig(args);
      break;
    case 'mcp':
      await cmdMcp();
      break;
    case 'agent':
      await cmdAgent(args);
      break;
    default:
      setErrorExit(`Unknown command: ${args.command}`);
      showHelp();
      process.exit(1);
  }
}

if (require.main === module) {
  main().catch((e) => {
    setApiErrorExit(e, 'Unexpected Trackly CLI failure');
  });
}

module.exports = {
  COMMAND_FLAGS,
  UNIVERSAL_FLAGS,
  cmdLogin,
  formatMaintenanceForHuman,
  getPublicConfig,
  hasJobListFilters,
  levenshtein,
  loginAccessError,
  main,
  nearestFlag,
  normalizeBaseUrlValue,
  openExternalUrl,
  parseArgs,
  parseExperienceLimits,
  parseJobId,
  writeLoginProgress,
};
