{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.kevinastuhuaman/trackly",
  "title": "Trackly CLI",
  "description": "AI job search agent. 128K+ jobs, 1,900+ companies, 40+ ATS types. Filter by role, location, visa.",
  "repository": {
    "url": "https://github.com/kevinastuhuaman/trackly-cli",
    "source": "github"
  },
  "websiteUrl": "https://usetrackly.app/cli",
  "icons": [
    {
      "src": "https://usetrackly.app/favicon-512x512.png?v=5",
      "mimeType": "image/png",
      "sizes": ["512x512"]
    }
  ],
  "version": "0.1.13",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "trackly-cli",
      "version": "0.1.13",
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "named",
          "name": "-y"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.usetrackly.app/api/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer API key (trk_*). Create one at https://usetrackly.app/settings",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
