{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.kevinastuhuaman/trackly",
  "title": "Trackly CLI",
  "description": "Job tracking CLI + MCP server for AI agents. 99K+ jobs, 775+ companies.",
  "repository": {
    "url": "https://github.com/kevinastuhuaman/trackly-cli",
    "source": "github"
  },
  "websiteUrl": "https://usetrackly.app/cli",
  "icons": [
    {
      "src": "https://usetrackly.app/favicon-512x512.png?v=5",
      "mimeType": "image/png",
      "sizes": ["512x512"]
    }
  ],
  "version": "0.1.4",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "trackly-cli",
      "version": "0.1.4",
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "named",
          "name": "-y"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
